# ─── AgentHire environment example ───────────────────────────────────────────
# Copy to `.env` and load with `export $(grep -v '^#' .env | xargs)` OR use a
# tool like `direnv` / `dotenv`. Every value has a safe default; the app boots
# fine with this file empty.

# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development              # development | testing | production
SECRET_KEY=change-me               # required in production
# DATABASE_URL=sqlite:///agenthire.db
# DATABASE_URL=postgresql://user:pass@host:5432/agenthire
# AUTO_SEED_DATA=1                 # set 0 in production (disable dev/demo fixture seeding)
# ENABLE_SIM_ENGINE=1              # set 0 in production unless explicitly needed
# STRICT_PROD_VALIDATION=1          # in production: fail fast on unsafe config

# ─── CORS / rate limit ────────────────────────────────────────────────────────
# CORS_ORIGINS=https://agenthire.io,https://app.agenthire.io
# RATELIMIT_DEFAULT=120/minute

# ─── API auth (protects /admin/* mutations) ──────────────────────────────────
# API_KEY=pick-a-long-random-string

# ─── On-chain: signer keys (hex, with or without 0x prefix) ──────────────────
# FACILITATOR_PRIVATE_KEY pays gas for the x402 flow (EIP-3009 → deposit).
# GATEKEEPER_PRIVATE_KEY signs dispute incidents; the public key MUST equal
#   ReputationContract.GATEKEEPER_ADDRESS() on the target chain or submission
#   will revert.
# FACILITATOR_PRIVATE_KEY=0x...
# GATEKEEPER_PRIVATE_KEY=0x...

# Optional Node-backed alternatives (proxy instead of Python-native path):
# FACILITATOR_URL=http://localhost:3000
# GATEKEEPER_URL=http://localhost:3001

# ─── On-chain: network ───────────────────────────────────────────────────────
# Defaults to Avalanche Fuji testnet. Override for a new chain/RPC.
# RPC_URL=https://api.avax-test.network/ext/C/rpc
# CHAIN_ID=43113
# CHAIN_NAME=Avalanche Fuji
# EXPLORER_URL=https://testnet.snowtrace.io

# ─── On-chain: contract addresses ────────────────────────────────────────────
# Set any subset to point the whole stack (backend + rendered JS) at your own
# deployment. Any unset value falls back to the Fuji hackathon deployment.
# MOCK_USDC_ADDRESS=0x...
# AGENT_REGISTRY_ADDRESS=0x...
# REPUTATION_ADDRESS=0x...
# STAKING_ADDRESS=0x...
# ESCROW_ADDRESS=0x...
# AUCTION_ADDRESS=0x...
